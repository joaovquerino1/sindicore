# SindiCore — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.

# ============================================================
# OBRIGATÓRIAS
# ============================================================

# Chave secreta para assinar tokens JWT.
# Gere uma chave segura com: openssl rand -base64 48
# NUNCA use o valor de exemplo em produção.
JWT_SECRET="troque-este-valor-por-uma-string-longa-e-aleatoria-no-mínimo-32-chars"

# URL de conexão com o banco de dados.
# Desenvolvimento (SQLite): file:./dev.db
# Produção (PostgreSQL):   postgresql://user:password@host:5432/sindicore
DATABASE_URL="file:./dev.db"

# ============================================================
# OPCIONAIS
# ============================================================

# Ambiente da aplicação. Detectado automaticamente se omitido.
# Valores: development | production | test
# NODE_ENV=production

# Porta do servidor HTTP. Padrão 3000.
# PORT=3000

# Hostname do servidor. Padrão 0.0.0.0.
# HOSTNAME=0.0.0.0

# Origem permitida para CORS quando rodando em domínio diferente.
# Lista separada por vírgulas. Use * apenas em desenvolvimento.
# ALLOWED_ORIGINS=https://sindicore.com.br,https://app.sindicore.com.br

# Nível de log estruturado.
# Valores: debug | info | warn | error
# LOG_LEVEL=info

# Limite de requisições por minuto por IP nas rotas de autenticação.
# Padrão: 10
# AUTH_RATE_LIMIT=10

# Tamanho máximo de upload em MB.
# UPLOAD_MAX_MB=10
